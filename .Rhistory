# =============================================================================
# PANEL DE PARÁMETROS  <-- acá modificás todo
# =============================================================================
# --- Archivos de entrada ---
ruta_imagen <- "01-04-2026.tif"        # Imagen Sentinel-2
ruta_lote   <- "Contono-loteRRR.shp"   # Shapefile del lote
# --- Clasificación ---
n_ambientes <- 3          # Número de ambientes (3, 4, 5...)
metodo_clasificacion <- "quantile"  # "quantile" o "equal" (intervalos iguales)
#quantile divide en grupos con igual cantidad de píxeles. equal divide el rango de NDVI en intervalos del mismo tamaño. En la práctica casi siempre se usa quantile.
# --- Nombres descriptivos de los ambientes (de menor a mayor NDVI) ---
nombres_ambientes <- c("Bajo", "Medio", "Alto")  # debe tener largo == n_ambientes
# --- Suavizado NDVI ---
ventana_suavizado    <- 5    # Tamaño de ventana (impar: 3, 5, 7...)
#Tiene que ser impar porque el píxel central tiene que tener la misma cantidad de vecinos a cada lado.
iteraciones_relleno  <- 10   # Iteraciones de relleno de NAs
# --- Filtro modal ---
ventana_modal <- 11   # Ventana del filtro de moda (mayor = manchas más grandes)
# Con menos ambientes (3) conviene bajar un poco la ventana respecto a cuando eran 5
# --- Suavizado de bordes Chaikin ---
refinements_chaikin <- 4   # Más = bordes más suaves (1-6)
#Recordar que poner muchas iteraciones ya no nos va mejorar mas la imagen
# --- Exportación ---
archivo_salida <- "ambientacion_definitiva_final_3zonas.shp"
# =============================================================================
# LIBRERÍAS
# =============================================================================
library(terra)
library(leaflet)
library(smoothr)
# =============================================================================
# 1. CARGAR DATOS
# =============================================================================
img  <- rast(ruta_imagen)
lote <- vect(ruta_lote)
crs(img) <- "EPSG:4326"
lote     <- project(lote, crs(img))
# =============================================================================
# 2. CALCULAR NDVI
# =============================================================================
img_crop <- crop(img, ext(lote) * 1.05)
ndvi_raw <- (img_crop[["B8"]] - img_crop[["B4"]]) / (img_crop[["B8"]] + img_crop[["B4"]])
ndvi_raw[ndvi_raw == 0] <- NA
# Suavizado
ndvi_s <- focal(ndvi_raw, w = ventana_suavizado, fun = "mean", na.rm = TRUE)
for(i in 1:iteraciones_relleno) {
ndvi_s <- focal(ndvi_s, w = ventana_suavizado, fun = "mean", na.rm = TRUE, NAonly = TRUE)
}
# =============================================================================
# 3. CLASIFICACIÓN
# =============================================================================
v <- values(ndvi_s, mat = FALSE)
if (metodo_clasificacion == "quantile") {
q   <- quantile(v, probs = seq(0, 1, length.out = n_ambientes + 1), na.rm = TRUE)
rcl <- matrix(c(q[1:n_ambientes], q[2:(n_ambientes+1)], 1:n_ambientes), ncol = 3)
} else {
rng <- range(v, na.rm = TRUE)
breaks <- seq(rng[1], rng[2], length.out = n_ambientes + 1)
rcl <- matrix(c(breaks[1:n_ambientes], breaks[2:(n_ambientes+1)], 1:n_ambientes), ncol = 3)
}
amb_raster <- classify(ndvi_s, rcl, include.lowest = TRUE)
amb_raster <- focal(amb_raster, w = ventana_modal, fun = "modal", na.rm = TRUE)
# =============================================================================
# 4. VECTORIZACIÓN
# =============================================================================
amb_poly        <- as.polygons(amb_raster, dissolve = TRUE)
names(amb_poly) <- "clase"
# =============================================================================
# 5. SUAVIZADO CHAIKIN
# =============================================================================
amb_m        <- project(amb_poly, "EPSG:3857")
amb_smooth_m <- smooth(amb_m, method = "chaikin", refinements = refinements_chaikin)
# =============================================================================
# 6. RECORTE AL LOTE
# =============================================================================
amb_final <- project(amb_smooth_m, crs(img))
lote_fix  <- project(lote, crs(img))
amb_final <- intersect(amb_final, lote_fix)
# --- Agregar columna con nombre descriptivo del ambiente ---
if (length(nombres_ambientes) != n_ambientes) {
stop("nombres_ambientes debe tener la misma longitud que n_ambientes")
}
amb_final$nombre <- nombres_ambientes[amb_final$clase]
# =============================================================================
# 7. VISUALIZACIÓN LEAFLET
# =============================================================================
# Paleta dinámica según n_ambientes
colores_base <- c("#d7191c", "#fdae61", "#ffffbf", "#a6d96a", "#1a9641",
"#2166ac", "#762a83")  # extras por si n_ambientes > 5
pal_ndvi <- colorNumeric(
palette  = "RdYlGn",
domain   = values(ndvi_s),
na.color = "transparent"
)
pal_amb <- colorFactor(
palette  = colores_base[1:n_ambientes],
domain   = 1:n_ambientes,
na.color = "transparent"
)
leaflet() %>%
addProviderTiles(providers$Esri.WorldImagery) %>%
addRasterImage(
mask(ndvi_s, lote_fix) |> terra::project("EPSG:4326"),
colors  = pal_ndvi,
opacity = 0.6,
group   = "NDVI"
) %>%
addPolygons(
data        = amb_final,
fillColor   = ~pal_amb(clase),
fillOpacity = 0.7,
color       = "white",
weight      = 0.5,
label       = ~nombre,
group       = "Ambientes"
) %>%
addPolygons(
data   = lote_fix,
fill   = FALSE,
color  = "cyan",
weight = 3,
group  = "Lote"
) %>%
addLegend(pal = pal_ndvi, values = values(ndvi_s),
title = "Valor NDVI", position = "bottomleft") %>%
addLegend(pal = pal_amb, values = 1:n_ambientes,
labFormat = function(type, cuts, p) nombres_ambientes,
title = "Ambientes", position = "bottomright") %>%
addLayersControl(
overlayGroups = c("NDVI", "Ambientes", "Lote"),
options = layersControlOptions(collapsed = FALSE)
)
# =============================================================================
# 8. EXPORTAR
# =============================================================================
writeVector(amb_final, archivo_salida, overwrite = TRUE)
cat("✓ Exportado:", archivo_salida, "\n")
cat("✓ Ambientes generados:", n_ambientes, "\n")
cat("✓ Nombres:", paste(nombres_ambientes, collapse = ", "), "\n")
# =============================================================================
# PANEL DE PARÁMETROS  <-- acá modificás todo
# =============================================================================
# --- Archivos de entrada ---
ruta_imagen <- "01-04-2026.tif"        # Imagen Sentinel-2
ruta_lote   <- "Contono-loteRRR.shp"   # Shapefile del lote
# --- Clasificación ---
n_ambientes <- 3          # Número de ambientes (3, 4, 5...)
metodo_clasificacion <- "quantile"  # "quantile" o "equal" (intervalos iguales)
#quantile divide en grupos con igual cantidad de píxeles. equal divide el rango de NDVI en intervalos del mismo tamaño. En la práctica casi siempre se usa quantile.
# --- Nombres descriptivos de los ambientes (de menor a mayor NDVI) ---
nombres_ambientes <- c("Bajo", "Medio", "Alto")  # debe tener largo == n_ambientes
# --- Suavizado NDVI ---
ventana_suavizado    <- 5    # Tamaño de ventana (impar: 3, 5, 7...)
#Tiene que ser impar porque el píxel central tiene que tener la misma cantidad de vecinos a cada lado.
iteraciones_relleno  <- 10   # Iteraciones de relleno de NAs
# --- Filtro modal ---
ventana_modal <- 11   # Ventana del filtro de moda (mayor = manchas más grandes)
# Con menos ambientes (3) conviene bajar un poco la ventana respecto a cuando eran 5
# --- Suavizado de bordes Chaikin ---
refinements_chaikin <- 4   # Más = bordes más suaves (1-6)
#Recordar que poner muchas iteraciones ya no nos va mejorar mas la imagen
# --- Exportación ---
archivo_salida <- "ambientacion_definitiva_final_verde.shp"
# =============================================================================
# LIBRERÍAS
# =============================================================================
library(terra)
library(leaflet)
library(smoothr)
# =============================================================================
# 1. CARGAR DATOS
# =============================================================================
img  <- rast(ruta_imagen)
lote <- vect(ruta_lote)
crs(img) <- "EPSG:4326"
lote     <- project(lote, crs(img))
# =============================================================================
# 2. CALCULAR NDVI
# =============================================================================
img_crop <- crop(img, ext(lote) * 1.05)
ndvi_raw <- (img_crop[["B8"]] - img_crop[["B4"]]) / (img_crop[["B8"]] + img_crop[["B4"]])
ndvi_raw[ndvi_raw == 0] <- NA
# Suavizado
ndvi_s <- focal(ndvi_raw, w = ventana_suavizado, fun = "mean", na.rm = TRUE)
for(i in 1:iteraciones_relleno) {
ndvi_s <- focal(ndvi_s, w = ventana_suavizado, fun = "mean", na.rm = TRUE, NAonly = TRUE)
}
# =============================================================================
# 3. CLASIFICACIÓN
# =============================================================================
v <- values(ndvi_s, mat = FALSE)
if (metodo_clasificacion == "quantile") {
q   <- quantile(v, probs = seq(0, 1, length.out = n_ambientes + 1), na.rm = TRUE)
rcl <- matrix(c(q[1:n_ambientes], q[2:(n_ambientes+1)], 1:n_ambientes), ncol = 3)
} else {
rng <- range(v, na.rm = TRUE)
breaks <- seq(rng[1], rng[2], length.out = n_ambientes + 1)
rcl <- matrix(c(breaks[1:n_ambientes], breaks[2:(n_ambientes+1)], 1:n_ambientes), ncol = 3)
}
amb_raster <- classify(ndvi_s, rcl, include.lowest = TRUE)
amb_raster <- focal(amb_raster, w = ventana_modal, fun = "modal", na.rm = TRUE)
# =============================================================================
# 4. VECTORIZACIÓN
# =============================================================================
amb_poly        <- as.polygons(amb_raster, dissolve = TRUE)
names(amb_poly) <- "clase"
# =============================================================================
# 5. SUAVIZADO CHAIKIN
# =============================================================================
amb_m        <- project(amb_poly, "EPSG:3857")
amb_smooth_m <- smooth(amb_m, method = "chaikin", refinements = refinements_chaikin)
# =============================================================================
# 6. RECORTE AL LOTE
# =============================================================================
amb_final <- project(amb_smooth_m, crs(img))
lote_fix  <- project(lote, crs(img))
amb_final <- intersect(amb_final, lote_fix)
# --- Agregar columna con nombre descriptivo del ambiente ---
if (length(nombres_ambientes) != n_ambientes) {
stop("nombres_ambientes debe tener la misma longitud que n_ambientes")
}
amb_final$nombre <- nombres_ambientes[amb_final$clase]
# =============================================================================
# 7. VISUALIZACIÓN LEAFLET
# =============================================================================
# Paleta dinámica según n_ambientes: siempre recorre todo el degradé rojo -> verde
colores_base <- colorRampPalette(c("#d7191c", "#fdae61", "#ffffbf", "#a6d96a", "#1a9641"))(n_ambientes)
pal_ndvi <- colorNumeric(
palette  = "RdYlGn",
domain   = values(ndvi_s),
na.color = "transparent"
)
pal_amb <- colorFactor(
palette  = colores_base,
domain   = 1:n_ambientes,
na.color = "transparent"
)
leaflet() %>%
addProviderTiles(providers$Esri.WorldImagery) %>%
addRasterImage(
mask(ndvi_s, lote_fix) |> terra::project("EPSG:4326"),
colors  = pal_ndvi,
opacity = 0.6,
group   = "NDVI"
) %>%
addPolygons(
data        = amb_final,
fillColor   = ~pal_amb(clase),
fillOpacity = 0.7,
color       = "white",
weight      = 0.5,
label       = ~nombre,
group       = "Ambientes"
) %>%
addPolygons(
data   = lote_fix,
fill   = FALSE,
color  = "cyan",
weight = 3,
group  = "Lote"
) %>%
addLegend(pal = pal_ndvi, values = values(ndvi_s),
title = "Valor NDVI", position = "bottomleft") %>%
addLegend(pal = pal_amb, values = 1:n_ambientes,
labFormat = function(type, cuts, p) nombres_ambientes,
title = "Ambientes", position = "bottomright") %>%
addLayersControl(
overlayGroups = c("NDVI", "Ambientes", "Lote"),
options = layersControlOptions(collapsed = FALSE)
)
# =============================================================================
# 8. EXPORTAR
# =============================================================================
writeVector(amb_final, archivo_salida, overwrite = TRUE)
cat("✓ Exportado:", archivo_salida, "\n")
cat("✓ Ambientes generados:", n_ambientes, "\n")
cat("✓ Nombres:", paste(nombres_ambientes, collapse = ", "), "\n")
install.packages('terra')

# PANEL DE PARÁMETROS  <-- acá modificás todo
# =============================================================================
# --- Archivos de entrada ---
ruta_imagen <- "01-04-2026.tif"        # Imagen Sentinel-2
ruta_lote   <- "Contono-loteRRR.shp"   # Shapefile del lote
# --- Clasificación ---
n_ambientes <- 3          # Número de ambientes (3, 4, 5...)
metodo_clasificacion <- "quantile"  # "quantile" o "equal" (intervalos iguales)
#quantile divide en grupos con igual cantidad de píxeles. equal divide el rango de NDVI en intervalos del mismo tamaño. En la práctica casi siempre se usa quantile.
# --- Nombres descriptivos de los ambientes (de menor a mayor NDVI) ---
nombres_ambientes <- c("Bajo", "Medio", "Alto")  # debe tener largo == n_ambientes
# --- Suavizado NDVI ---
ventana_suavizado    <- 5    # Tamaño de ventana (impar: 3, 5, 7...)
#Tiene que ser impar porque el píxel central tiene que tener la misma cantidad de vecinos a cada lado.
iteraciones_relleno  <- 10   # Iteraciones de relleno de NAs
# --- Filtro modal ---
ventana_modal <- 11   # Ventana del filtro de moda (mayor = manchas más grandes)
# Con menos ambientes (3) conviene bajar un poco la ventana respecto a cuando eran 5
# --- Suavizado de bordes Chaikin ---
refinements_chaikin <- 4   # Más = bordes más suaves (1-6)
#Recordar que poner muchas iteraciones ya no nos va mejorar mas la imagen
# --- Exportación ---
archivo_salida <- "ambientacion_definitiva_final_3zonas.shp"
# =============================================================================
# LIBRERÍAS
# =============================================================================
library(terra)
library(leaflet)
library(smoothr)
# =============================================================================
# 1. CARGAR DATOS
# =============================================================================
img  <- rast(ruta_imagen)
